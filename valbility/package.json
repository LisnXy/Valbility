{
  "name": "valbility",
  "productName": "Valbility",
  "version": "1.0.3",
  "description": "Game audio mute utility for VALORANT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "lint": "echo \"No linting configured\"",
    "build": "electron-builder"
  },
  "repository": "https://github.com/LisnXy/Valbility",
  "publish": {
    "provider": "github",
    "releaseType": "release"
  },
  "build": {
    "appId": "com.valbility.Valbility",
    "productName": "Valbility",
    "win": {
      "artifactName": "${productName}-Setup.${ext}",
      "target": [
        "nsis"
      ],
      "icon": "./assets/icons/256_256.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "./assets/icons/256_256.ico",
      "uninstallerIcon": "./assets/icons/256_256.ico",
      "uninstallDisplayName": "Valbility Uninstaller",
      "license": "license.md",
      "allowToChangeInstallationDirectory": false
    },
    "asarUnpack": [
      "node_modules/active-win/lib/binding/**/*.node",
      "node_modules/native-sound-mixer/dist/addons/win-sound-mixer.node",
      "node_modules/ps-list/fastlist.exe",
      "node_modules/uiohook-napi/prebuilds/win32-x64/uiohook-napi.node"
    ]
  },
  "keywords": [
    "Valbility",
    "VALORANT",
    "Game Mute",
    "Auto Mute",
    "Accessibility"
  ],
  "author": {
    "name": "Mark Zhdan",
    "email": "valbility@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "active-win": "^8.1.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^5.3.0",
    "native-sound-mixer": "^3.3.0",
    "prebuild-install": "^7.1.1",
    "ps-list": "^6.3.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.2.10",
    "electron": "^23.1.1",
    "electron-builder": "^23.6.0"
  }
}
